{
  "name": "Lint on Save",
  "version": "1.0.0",
  "description": "Automatically format and lint Python files on save using black, isort, and flake8",
  "when": {
    "type": "fileEdited",
    "patterns": ["*.py"]
  },
  "then": {
    "type": "runCommand",
    "command": "black --quiet ${file} && isort --quiet ${file} && flake8 --quiet ${file} 2>/dev/null || true"
  }
}
